# =============================================================
# Claude Code Token Monitor - 環境変数設定
# =============================================================
# このファイルを .env にコピーして値を設定してください:
#   cp .env.example .env
# =============================================================

# --- 必須 ---

# Anthropic API Key
# 取得方法: https://console.anthropic.com/settings/keys > API Keys > Create Key
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Teams 通知 (任意) ---

# Microsoft Teams Incoming Webhook URL
# 取得方法:
#   1. Teamsで通知先チャンネルを開く
#   2. チャンネル名の右の「...」> ワークフロー > 「Incoming Webhook」
#   3. Webhook名を入力して「追加」
#   4. 表示されるURLをここに貼り付け
TEAMS_WEBHOOK_URL=

# --- オプション ---

# API呼び出しのベースURL (通常は変更不要)
# ANTHROPIC_API_URL=https://api.anthropic.com

# ヘルスチェックに使用するモデル (トークン消費を最小限にするため軽量モデル推奨)
# CHECK_MODEL=claude-sonnet-4-6

# 確認間隔 (分) - デフォルト: 60
# CHECK_INTERVAL_MINUTES=60

# 通知閾値 (%) - トークン残量がこの値以下で警告 - デフォルト: 20
# ALERT_THRESHOLD=20

# Webサーバーポート - デフォルト: 3000
# PORT=3000

# Webサーバーホスト - デフォルト: 0.0.0.0
# HOST=0.0.0.0

# 履歴保持件数 - デフォルト: 168 (1時間ごとで約7日分)
# MAX_HISTORY=168
